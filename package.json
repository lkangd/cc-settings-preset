{
  "name": "@lkangd/cc-settings-preset",
  "version": "1.0.3",
  "description": "A switchable, reusable runtime settings preset selector for Claude Code",
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "settings",
    "preset",
    "presets",
    "configuration",
    "cli",
    "ccsp",
    "mcp",
    "plugins",
    "skills",
    "developer-tools",
    "tui"
  ],
  "homepage": "https://github.com/lkangd/cc-settings-preset#readme",
  "bugs": {
    "url": "https://github.com/lkangd/cc-settings-preset/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lkangd/cc-settings-preset.git"
  },
  "author": "",
  "license": "ISC",
  "type": "module",
  "bin": {
    "cc-settings-preset": "dist/cli.js",
    "ccsp": "dist/cli.js"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@9.5.0",
  "scripts": {
    "generate-version": "node scripts/generate-version.mjs",
    "postinstall": "pnpm run generate-version",
    "pretypecheck": "pnpm run generate-version",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prebuild": "pnpm run generate-version",
    "pretest": "pnpm run generate-version",
    "build": "tsc -p tsconfig.build.json",
    "predev": "pnpm run generate-version",
    "postbuild": "chmod +x dist/cli.js",
    "prepack": "pnpm run build",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "check": "pnpm run typecheck && pnpm run build && pnpm run test",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20.19.2"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.0",
    "cross-spawn": "^7.0.6",
    "figlet": "^1.9.3",
    "gradient-string": "^3.0.0",
    "ink": "^6.3.1",
    "react": "^19.2.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/figlet": "^1.7.0",
    "@types/fs-extra": "^11.0.4",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^20.19.25",
    "@types/react": "^19.2.7",
    "@types/react-test-renderer": "^19.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "react-test-renderer": "^19.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}