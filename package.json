{
  "name": "@lkangd/cc-settings-preset",
  "version": "1.0.0",
  "description": "A preset selector for Claude Code runtime settings",
  "homepage": "https://github.com/lkangd/cc-settings-preset#readme",
  "bugs": {
    "url": "https://github.com/lkangd/cc-settings-preset/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lkangd/cc-settings-preset.git"
  },
  "author": "",
  "license": "ISC",
  "type": "module",
  "bin": {
    "cc-settings-preset": "dist/cli.js",
    "ccsp": "dist/cli.js"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@9.5.0",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/cli.js",
    "prepack": "pnpm run build",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "check": "pnpm run typecheck && pnpm run build && pnpm run test",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20.19.2"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "commander": "^14.0.0",
    "cross-spawn": "^7.0.6",
    "figlet": "^1.9.3",
    "fs-extra": "^11.3.2",
    "gradient-string": "^3.0.0",
    "ink": "^6.3.1",
    "pino": "^10.1.0",
    "react": "^19.2.1",
    "yaml": "^2.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/figlet": "^1.7.0",
    "@types/fs-extra": "^11.0.4",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^20.19.25",
    "@types/react": "^19.2.7",
    "@types/react-test-renderer": "^19.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "execa": "^9.6.0",
    "react-test-renderer": "^19.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
